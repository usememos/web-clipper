# All build-time config lives in .env — the single env file for both `vite dev` and
# `vite build`, so the extension you test is configured exactly like the one you ship.
# Copy this file to .env and fill in real values.

# Clerk public OAuth application. Configure the app as public (PKCE), grant
# openid, profile, and public_metadata, and register the redirect URLs printed by
# chrome.identity.getRedirectURL() / browser.identity.getRedirectURL() for each store build.
VITE_CLERK_OAUTH_CLIENT_ID=your_clerk_oauth_client_id
VITE_CLERK_OAUTH_ISSUER=https://clerk.your-domain.com
# The web app remains the only place that writes Clerk unsafe metadata.
VITE_WEB_APP_URL=https://your-domain.com
